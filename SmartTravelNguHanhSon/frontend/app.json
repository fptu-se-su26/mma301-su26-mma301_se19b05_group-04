{
  "expo": {
    "name": "Smart Travel Ngũ Hành Sơn",
    "slug": "smart-travel-ngu-hanh-son",
    "scheme": "smarttravel1",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0EA5E9",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buu.smarttravel1"
    },
    "android": {
      "package": "com.buu.smarttravel1",
      "adaptiveIcon": {
        "backgroundColor": "#0EA5E9"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
